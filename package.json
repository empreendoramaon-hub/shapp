{
  "name": "shapp-landing",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:rules": "firebase emulators:exec --project demo-shapp-security --only firestore,storage \"node --test tests/firebase.rules.test.mjs\"",
    "security:check": "npm audit --audit-level=high && npm run test:rules && npm run build"
  },
  "dependencies": {
    "@vitejs/plugin-react": "latest",
    "vite": "latest",
    "react": "latest",
    "react-dom": "latest",
    "firebase": "latest",
    "lucide-react": "latest",
    "qrcode.react": "latest"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "latest",
    "firebase-tools": "latest"
  }
}
