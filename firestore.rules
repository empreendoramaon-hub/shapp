rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() && request.auth.token.admin == true;
    }

    function isAcademyAdmin(academyId) {
      return isAdmin()
        && (request.auth.token.academyId == academyId
          || request.auth.token.superAdmin == true);
    }

    function isMember(academyId, memberId) {
      return signedIn()
        && get(/databases/$(database)/documents/academies/$(academyId)/members/$(memberId)).data.authUid == request.auth.uid;
    }

    match /landingLeads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'email', 'profile', 'interest', 'createdAt', 'source'
      ])
      && request.resource.data.email is string
      && request.resource.data.email.size() >= 3
      && request.resource.data.email.size() <= 160
      && request.resource.data.name is string
      && request.resource.data.name.size() >= 2
      && request.resource.data.name.size() <= 90
      && request.resource.data.profile is string
      && request.resource.data.profile.size() <= 50
      && request.resource.data.interest is string
      && request.resource.data.interest.size() <= 500
      && request.resource.data.source is string
      && request.resource.data.source.size() <= 80
      && (request.resource.data.createdAt is string
        || request.resource.data.createdAt is timestamp);

      allow read, update, delete: if false;
    }

    match /academies/{academyId}/members/{memberId} {
      allow create, delete: if isAcademyAdmin(academyId);
      allow read: if isAcademyAdmin(academyId)
        || (signedIn() && resource.data.authUid == request.auth.uid);
      allow update: if isAcademyAdmin(academyId)
        || (isMember(academyId, memberId)
          && request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'bookedClasses', 'noticesRead'
          ])
          && request.resource.data.bookedClasses is list
          && request.resource.data.bookedClasses.size() <= 50
          && request.resource.data.noticesRead is list
          && request.resource.data.noticesRead.size() <= 100);
    }

    match /academies/{academyId}/appEvents/{eventId} {
      allow create: if request.resource.data.keys().hasOnly([
          'activityId', 'classDate', 'classId', 'classPlace', 'classTime', 'classTitle',
          'createdAt', 'memberId', 'memberName', 'source', 'type', 'workoutId'
        ])
        && (!('memberId' in request.resource.data) || request.resource.data.memberId is string)
        && request.resource.data.type is string
        && request.resource.data.type.size() <= 80
        && request.resource.data.createdAt is timestamp
        && isAcademyAdmin(academyId);
      allow read: if isAcademyAdmin(academyId);
      allow update, delete: if false;
    }

    match /academies/{academyId}/activities/{activityId} {
      allow read: if true;
      allow create, update, delete: if isAcademyAdmin(academyId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
