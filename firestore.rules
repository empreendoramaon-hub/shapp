rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /landingLeads/{leadId} {
      allow create: if request.resource.data.keys().hasOnly([
        'name', 'email', 'profile', 'interest', 'createdAt', 'source'
      ])
      && request.resource.data.email is string
      && request.resource.data.email.size() <= 160
      && request.resource.data.name is string
      && request.resource.data.name.size() <= 90
      && request.resource.data.profile is string
      && request.resource.data.interest is string;

      allow read, update, delete: if false;
    }
  }
}
