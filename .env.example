# Links dos 3 produtos. Troque quando criar os projetos na Vercel.
VITE_SHAPP_FIT_URL=https://shappfit.vercel.app
VITE_SHAPP_COACH_URL=https://shapp-coach.vercel.app
VITE_SHAPP_GYM_URL=https://shapp-gym.vercel.app

# Firebase opcional para capturar leads da landing.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Chave publica de site do reCAPTCHA Enterprise usada pelo Firebase App Check.
# Registre os dominios no Firebase antes de ativar o enforcement.
VITE_RECAPTCHA_ENTERPRISE_SITE_KEY=

# Nunca use VITE_ para segredos. Variaveis VITE_* fazem parte do bundle publico.
# Exemplos que devem existir apenas em funcoes/backend (sem VITE_):
# FIREBASE_PRIVATE_KEY=
# FIREBASE_CLIENT_EMAIL=
# ADMIN_API_SECRET=
